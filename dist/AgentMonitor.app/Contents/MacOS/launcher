#!/bin/bash
# Agent Monitor 启动器
# 双击运行即可启动监控服务

# 获取脚本所在目录
SCRIPT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
APP_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# 切换到应用目录
cd "$APP_DIR"

# 检查 Python3
if ! command -v python3 &> /dev/null; then
    osascript -e 'display dialog "请先安装 Python3\n\n访问: https://www.python.org/downloads/" buttons {"确定"} default button "确定" with title "Agent Monitor" with icon stop'
    exit 1
fi

# 检查依赖
if ! python3 -c "import requests" 2>/dev/null; then
    osascript -e 'display dialog "正在安装依赖...\n\n首次运行需要安装 requests 库" buttons {"确定"} default button "确定" with title "Agent Monitor"'
    pip3 install requests 2>/dev/null || pip install requests 2>/dev/null
fi

# 检查端口
if lsof -i :9001 > /dev/null 2>&1; then
    osascript -e 'display dialog "端口 9001 已被占用\n\n请先关闭占用该端口的程序" buttons {"确定"} default button "确定" with title "Agent Monitor" with icon caution'
    exit 1
fi

# 初始化数据
echo "正在初始化数据..."
python3 monitor.py > /dev/null 2>&1

# 启动服务
echo "正在启动服务..."
python3 server.py > /tmp/agent-monitor.log 2>&1 &
SERVER_PID=$!

# 等待服务启动
sleep 2

# 检查服务是否启动成功
if ! lsof -i :9001 > /dev/null 2>&1; then
    osascript -e 'display dialog "服务启动失败\n\n请查看日志: /tmp/agent-monitor.log" buttons {"确定"} default button "确定" with title "Agent Monitor" with icon stop'
    exit 1
fi

# 打开浏览器
open "http://localhost:9001"

# 显示成功提示
osascript -e 'display dialog "Agent Monitor 已启动！\n\n访问地址: http://localhost:9001\n\n点击确定打开浏览器" buttons {"确定"} default button "确定" with title "Agent Monitor"'

echo "Agent Monitor 已启动 (PID: $SERVER_PID)"
echo "访问地址: http://localhost:9001"
echo "按 Ctrl+C 停止服务"

# 保持运行
wait $SERVER_PID